# Medify backend — انسخ إلى .env للتطوير المحلي (لا أسرار حقيقية في المستودع)
DATABASE_URL=postgresql+psycopg://medify_app:medify_app@localhost:5432/medify
MIGRATIONS_DATABASE_URL=postgresql+psycopg://medify_owner:medify_dev_pw@localhost:5432/medify
JWT_SECRET=change-me
COLUMN_ENCRYPTION_KEY=change-me-32-bytes
PAYMENT_WEBHOOK_SECRET=change-me
STT_ENGINE=mock          # whisper | mock
LLM_ENGINE=mock          # claude | mock
ANTHROPIC_API_KEY=
INTEGRATION_ENGINE=mock  # mock | http
EMAIL_ENGINE=mock
ENVIRONMENT=dev
FRONTEND_ORIGIN=http://localhost:3000
