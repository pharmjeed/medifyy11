# نشر Medify على Oracle Cloud — انسخ إلى deploy.env واملأ القيم ثم:
#   bash infra/deploy/oracle.sh
ORACLE_HOST=            # عنوان IP العام للخادم (إلزامي)
ORACLE_USER=ubuntu      # يجرَّب opc تلقائياً إن فشل
ORACLE_SSH_KEY=~/.ssh/id_rsa
# اختياري:
DOMAIN=                 # وجود دومين = TLS تلقائي عبر Caddy
ANTHROPIC_API_KEY=      # غيابه = LLM_ENGINE=mock (يعمل كل شيء بعينات تجريبية)
REPO_URL=https://github.com/pharmjeed/medifyy11.git
GIT_REF=v0.1.0
